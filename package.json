{
  "name": "reddit-monitor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @reddit-monitor/web dev",
    "build": "pnpm --filter @reddit-monitor/db generate && pnpm --filter @reddit-monitor/web build",
    "crawler": "pnpm --filter @reddit-monitor/crawler start",
    "db:generate": "pnpm --filter @reddit-monitor/db generate",
    "db:migrate:dev": "pnpm --filter @reddit-monitor/db migrate:dev",
    "db:studio": "pnpm --filter @reddit-monitor/db studio",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test",
    "docker:up": "docker-compose up -d",
    "ai:checks": "bash scripts/run-checks.sh",
    "docker:down": "docker-compose down",
    "ai:phase-review": "pnpm ai:prepare-hermes-review && cat .ai/hermes-review-prompt.md",
    "ai:prepare-hermes-review": "node scripts/prepare-hermes-review.js",
    "bokun:booking:payload": "node scripts/bokun-booking-payload-builder.js"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
