# ── Database ──────────────────────────────────────────────────────────────────
# Dev: direct connection (port 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reddit_monitor_dev
# Production (Supabase): use pgbouncer port 6543 + connection_limit=1 for serverless
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Reddit OAuth ──────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=reddit-monitor/1.0 by u/yourusername

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender domain in Resend dashboard
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID from Stripe Dashboard (Products → your Pro plan → price ID)
STRIPE_PRO_PRICE_ID=price_...

# ── Supabase Auth ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Internal API ──────────────────────────────────────────────────────────────
# URL of the Next.js app that the crawler posts matches to
INTERNAL_API_URL=http://localhost:3000
# Shared secret between crawler and web API (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=
