# ── Database ──────────────────────────────────────────────────────────────────
# Dev: direct connection (port 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reddit_monitor_dev
# Production (Supabase): use pgbouncer port 6543 + connection_limit=1 for serverless
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1
POSTGRES_PASSWORD=postgres

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender domain in Resend dashboard
RESEND_FROM_EMAIL=hello@radarscout.io

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Bókun ─────────────────────────────────────────────────────────────────────
# Server-side only. Never expose these through NEXT_PUBLIC_* variables.
BOKUN_ACCESS_KEY=
BOKUN_SECRET_KEY=
BOKUN_API_BASE_URL=https://api.bokun.io
BOKUN_DEFAULT_CURRENCY=USD
# Shared secret for triggering the server-only Bókun sync endpoint.
BOKUN_SYNC_SECRET=

# ── Internal API ──────────────────────────────────────────────────────────────
# Shared secret for server-side sync endpoints. Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# ── Optional legacy SaaS integrations ─────────────────────────────────────────
# Keep unset for the Thailand travel MVP unless these flows are intentionally enabled.
REDIS_URL=redis://localhost:6379
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_TEAM_ANNUAL_PRICE_ID=price_...
INTERNAL_API_URL=http://localhost:3000
