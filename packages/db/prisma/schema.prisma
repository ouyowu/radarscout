generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
  TEAM
}

enum Platform {
  REDDIT
  HN
  X
  QUORA
  RSS
  FORUM
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  passwordHash       String
  plan               Plan           @default(FREE)
  stripeCustomerId   String?
  productDescription String?
  emailEnabled       Boolean        @default(true)
  createdAt          DateTime       @default(now())
  keywords           Keyword[]
  notifications      Notification[]
  campaigns          Campaign[]
}

model Campaign {
  id             String       @id @default(uuid())
  userId         String
  name           String
  description    String?
  industry       String?
  targetCustomer String?
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords       Keyword[]
  competitors    Competitor[]

  @@index([userId])
}

model Competitor {
  id         String   @id @default(uuid())
  campaignId String
  name       String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Keyword {
  id         String    @id @default(uuid())
  userId     String
  campaignId String?
  text       String
  flags      Json      @default("{}")
  enabled    Boolean   @default(true)
  dailyHits  Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  matches    Match[]

  @@index([campaignId])
}

model Match {
  id              String   @id @default(uuid())
  keywordId       String
  platform        Platform
  postId          String
  title           String
  url             String
  snippet         String
  matchedAt       DateTime @default(now())
  intentScore     Int?
  aiSummary       String?  @db.VarChar(200)
  aiReplyDraft    String?
  painPoints      String?
  opportunityType String?
  competitors     String[]
  location         String?
  contentCategory  String?
  travelIntentScore Int?
  credibilityScore Int?
  commercialScore  Int?
  sourceMeta       Json     @default("{}")
  keyword         Keyword  @relation(fields: [keywordId], references: [id])

  @@unique([keywordId, postId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  deliveredAt DateTime @default(now())
  matchCount  Int
  user        User     @relation(fields: [userId], references: [id])
}

model BokunSupplier {
  id             String         @id @default(uuid())
  bokunVendorId  String         @unique
  title          String
  status         String?
  rawJson        Json           @default("{}")
  lastSyncedAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  products       BokunProduct[]

  @@index([title])
}

model BokunProduct {
  id                 String         @id @default(uuid())
  bokunActivityId    String         @unique
  supplierId         String?
  title              String
  description        String?
  excerpt            String?
  city               String?
  location           String?
  retailPrice        Decimal?       @db.Decimal(10, 2)
  netSettlementPrice Decimal?       @db.Decimal(10, 2)
  currency           String?
  commissionPercent  Decimal?       @db.Decimal(5, 2)
  active             Boolean        @default(true)
  rawJson            Json           @default("{}")
  lastSyncedAt       DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  supplier           BokunSupplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  bookingInquiries   BookingInquiry[]
  productTags        ProductTag[]

  @@index([supplierId])
  @@index([city])
  @@index([active])
  @@index([title])
}

model ProductTag {
  id         String       @id @default(uuid())
  productId  String
  tagName    String
  score      Decimal      @db.Decimal(5, 2)
  active     Boolean      @default(true)
  lastSeenAt DateTime     @default(now())
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  product    BokunProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([productId, tagName])
  @@index([productId])
  @@index([tagName])
  @@index([active])
}

model BookingInquiry {
  id              String       @id @default(uuid())
  bokunProductId  String
  travelDate      DateTime
  adults          Int
  children        Int          @default(0)
  pickupArea      String
  customerName    String
  customerEmail   String
  whatsapp        String?
  notes           String?
  status          String       @default("new")
  createdAt       DateTime     @default(now())
  product         BokunProduct @relation(fields: [bokunProductId], references: [id], onDelete: Restrict)

  @@index([bokunProductId])
  @@index([customerEmail])
  @@index([status])
  @@index([createdAt])
}
